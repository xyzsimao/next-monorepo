{
  "name": "next-monorepo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "tool:test": "pnpm --filter=@workspace/ui_cli test",
    "test:dev": "turbo run test   --force",
    "test": "start-server-and-test v4:dev http://localhost:4000 test:dev",
    "validate:registries": "pnpm --filter=v4 validate:registries",
    "test:apps": "pnpm --filter=v4 test:apps"
  },
  "dependencies": {
    "eslint-plugin-tailwindcss": "3.13.1",
    "tailwindcss": "^3.4.18",
    "prettier": "^3.4.2",
    "pretty-quick": "^4.0.0",
    "vite": "^7.1.12",
    "puppeteer": "^23.6.0",
    "chokidar": "^4.0.3",
    "vite-tsconfig-paths": "^4.2.0",
    "vitest": "^2.1.9"
  },
  "devDependencies": {
    "@types/node": "^20.11.27",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "@ianvs/prettier-plugin-sort-imports": "^4.6.1",
    "prettier": "^3.8.3",
    "tsx": "^4.1.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "start-server-and-test": "^2.0.12",
    "turbo": "^2.9.15",
    "typescript": "^5.5.3"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20"
  }
}